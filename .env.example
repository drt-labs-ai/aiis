# =============================================================================
# AIIS — Environment Configuration
# Copy this file to .env and fill in values for your environment.
# =============================================================================

# ─── LLM Provider ─────────────────────────────────────────────────────────────
# Global default provider. Options: anthropic | openai | ollama
# If not set, auto-detected from API keys (anthropic > openai > ollama).
LLM_PROVIDER=ollama

# ─── Per-Agent Model Overrides ────────────────────────────────────────────────
# Each agent role can use a different provider and model.
# Useful for cost optimisation: cheap/fast model for routing, powerful for investigation.
#
# Supervisor agent — triage and routing (low latency, simple reasoning)
SUPERVISOR_LLM_PROVIDER=ollama
SUPERVISOR_LLM_MODEL=llama3.1:8b

# Domain agents — root-cause analysis and report generation (needs better reasoning)
DOMAIN_AGENT_LLM_PROVIDER=ollama
DOMAIN_AGENT_LLM_MODEL=llama3.1:8b

# ─── Anthropic Claude ─────────────────────────────────────────────────────────
# Used when LLM_PROVIDER=anthropic or SUPERVISOR/DOMAIN_AGENT_LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ─── OpenAI / OpenAI-compatible ───────────────────────────────────────────────
# Used when LLM_PROVIDER=openai or per-agent provider=openai.
# OPENAI_BASE_URL lets you point at any OpenAI-compatible endpoint:
#   - OpenAI cloud:     leave blank (default)
#   - vLLM on OpenStack: http://<vllm-vm-ip>:8000/v1
#   - Azure OpenAI:      https://<your-resource>.openai.azure.com
#   - LM Studio (local): http://localhost:1234/v1
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# ─── Ollama (local / GPU VM) ──────────────────────────────────────────────────
# Used when LLM_PROVIDER=ollama or per-agent provider=ollama.
# Change OLLAMA_BASE_URL when Ollama runs on a separate machine (e.g. GPU VM on OpenStack).
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ─── GitHub Integration ───────────────────────────────────────────────────────
# Personal access token with issues:write and repo:read permissions
GITHUB_TOKEN=ghp_...

# Target repository in "owner/repo" format
GITHUB_REPO=your-org/your-repo

# HMAC secret shared with GitHub webhook (generate: python3 -c "import secrets; print(secrets.token_hex(32))")
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# ─── Kafka (event bus) ────────────────────────────────────────────────────────
# When set, all observability events are published to Kafka topic aiis.observability
# and the built-in ES-sink consumer writes them to Elasticsearch with full payloads.
# When empty (default for local dev without Docker), events go directly to ES.
#
# Local (docker compose):    kafka:9092
# External / hosted Kafka:   <broker-host>:<port>
KAFKA_BOOTSTRAP_SERVERS=

# ─── Elasticsearch ────────────────────────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200

# ─── ChromaDB / RAG ───────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma
EMBED_MODEL=all-MiniLM-L6-v2
KNOWLEDGE_BASE_DIR=./knowledge-base

# ─── Agent Tuning ─────────────────────────────────────────────────────────────
MAX_INVESTIGATION_ITERATIONS=4
CONFIDENCE_THRESHOLD=0.75

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
