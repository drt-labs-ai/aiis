# ─── LLM Backend (use one or the other) ──────────────────────────────────────
# Option A: Anthropic Claude (cloud)
ANTHROPIC_API_KEY=sk-ant-...

# Option B: Ollama (local — used automatically when ANTHROPIC_API_KEY is not set)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# GitHub personal access token (needs: issues:write, repo:read)
GITHUB_TOKEN=ghp_...

# Target repository in "owner/repo" format
GITHUB_REPO=your-org/your-repo

# ─── Optional ─────────────────────────────────────────────────────────────────
# Webhook HMAC secret (set in GitHub webhook settings)
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200

# Vector DB
CHROMA_PERSIST_DIR=./data/chroma
EMBED_MODEL=all-MiniLM-L6-v2

# Knowledge base path
KNOWLEDGE_BASE_DIR=./knowledge-base

# Agent tuning
MAX_INVESTIGATION_ITERATIONS=4
CONFIDENCE_THRESHOLD=0.75

# Logging
LOG_LEVEL=INFO
